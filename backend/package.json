{
  "name": "livestream-backend",
  "version": "1.0.0",
  "description": "Backend Lambda functions for livestream platform",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "sam-build": "sam build",
    "sam-local": "sam local start-api --env-vars env.json",
    "sam-local:debug": "sam local start-api --env-vars env.json --debug",
    "sam-deploy": "sam deploy --guided",
    "dev": "npm run build && sam build && sam local start-api --env-vars env.json",
    "sls:offline": "serverless offline",
    "sls:offline:dynamodb": "serverless offline start",
    "sls:deploy": "serverless deploy",
    "sls:deploy:dev": "serverless deploy --stage dev",
    "sls:remove": "serverless remove"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.490.0",
    "@aws-sdk/lib-dynamodb": "^3.490.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "stripe": "^14.7.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.130",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "serverless": "^3.38.0",
    "serverless-dynamodb-local": "^0.2.40",
    "serverless-offline": "^13.3.0",
    "typescript": "^5.3.3"
  }
}

